// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------

enum MerchantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TransactionStatus {
  PENDING_3D
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  VOIDED
}

enum FlowType {
  AUTOMATIC // 3D Pay: 3D success -> auth/capture immediately
  MANUAL    // 3D Model: 3D success -> only verify, merchant calls auth/capture later
}

enum ThreeDSecureStatus {
  PENDING
  SUCCESS
  FAILED
}

enum SecureMode {
  SECURE     // 3D Secure flow with redirect
  NONSECURE  // Direct processing, no 3D redirect
}

// -----------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------

model Merchant {
  id         String         @id @default(uuid())
  name       String
  api_key    String         @unique
  secret_key String         @unique
  status     MerchantStatus @default(ACTIVE)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("merchants")
}

model Transaction {
  id          String   @id @default(uuid()) // Our Bank Reference
  merchant_id String
  merchant    Merchant @relation(fields: [merchant_id], references: [id])
  order_id    String   @unique // HSRCPAY reference

  amount   Int // In smallest currency unit (cents, kurus)
  currency String @default("TRY")

  card_bin   String
  card_last4 String

  status          TransactionStatus @default(PENDING_3D)
  secure_mode     SecureMode        @default(SECURE)
  flow_type       FlowType          @default(AUTOMATIC)
  is_auto_capture Boolean           @default(true) // true = Capture (Sale), false = Auth (Pre-auth)
  return_url_ok   String // Callback URL on success
  return_url_fail String // Callback URL on failure

  three_d_logs ThreeDSecureLog[]
  events       TransactionEventLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transactions")
}

model ThreeDSecureLog {
  id             String      @id @default(uuid())
  transaction_id String
  transaction    Transaction @relation(fields: [transaction_id], references: [id])

  verification_code String
  status            ThreeDSecureStatus @default(PENDING)
  payload           Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("three_d_secure_logs")
}

model TransactionEventLog {
  id             String      @id @default(uuid())
  transaction_id String
  transaction    Transaction @relation(fields: [transaction_id], references: [id])

  event_type String // e.g., 'PAYMENT_STARTED', '3D_COMPLETED', 'CAPTURE_EXECUTED'
  payload    Json?

  createdAt DateTime @default(now())

  @@map("transaction_event_logs")
}
